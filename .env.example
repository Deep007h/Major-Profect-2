# Server Port
PORT=3000

# Session Secret (change in production!)
SESSION_SECRET=your_secure_random_secret_here

# Path to the yt-dlp binary used for audio streaming.
# Defaults to /tmp/yt-dlp if unset. Download from https://github.com/yt-dlp/yt-dlp
YT_DLP_PATH=/tmp/yt-dlp

# Optional: override the YouTube Music InnerTube API key
# YT_INNERTUBE_KEY=

# NOTE: This app stores data locally with NeDB (data/songs.db, data/users.db).
# No external database (e.g. MongoDB) is required.
