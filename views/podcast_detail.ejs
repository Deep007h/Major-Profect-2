<% if (locals.layout === false) { %>
  <%- include('podcast_detail_content.ejs', { podcastData, browseId }) %>
<% } else { %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= podcastData.name || 'Podcast' %> | MusicKey</title>
  <link rel="icon" type="image/png" href="/assets/main-logo.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css?v=4.5">
</head>
<body data-user-logged-in="<%= locals.user ? 'true' : 'false' %>">
  <div class="app-container">
    <header class="top-bar">
      <div class="top-bar-left">
        <a href="/spotify" class="spotify-logo-link" title="MusicKey">
          <svg viewBox="0 0 24 24" height="32" width="32" fill="#fff" class="spotify-logo"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424c-.18.295-.565.387-.86.207-2.377-1.454-5.37-1.783-8.892-.982-.336.076-.67-.135-.746-.47-.077-.337.135-.67.472-.747 3.854-.88 7.15-.508 9.818 1.127.294.18.387.563.208.865z"/></svg>
        </a>
      </div>
      <div class="top-bar-center">
        <a href="/spotify" class="home-btn" title="Home"><i class="fa-solid fa-house"></i></a>
        <div class="search-wrap"><form class="search-box" onsubmit="return handleSearch(event)"><i class="fa-solid fa-magnifying-glass search-icon"></i><input id="searchInput" type="text" placeholder="What do you want to play?" autocomplete="off"><span class="search-divider"></span><button type="button" class="browse-btn"><i class="fa-solid fa-book"></i></button></form><div class="search-results-dropdown" id="searchResults"></div></div>
      </div>
      <div class="top-bar-right">
        <% if (locals.user) { %><a href="/spotify/logout" class="profile-avatar"><%= locals.user.username.charAt(0).toUpperCase() %></a><% } else { %><a href="/spotify/signup" class="signup-link">Sign up</a><a href="/spotify/login" class="login-btn">Log in</a><% } %>
      </div>
    </header>

    <div class="main-area">
      <aside class="sidebar">
        <div class="sidebar-section sidebar-library-section">
          <div class="sidebar-library-header">
            <span class="lib-left">
              <svg class="lib-icon" role="img" height="24" width="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 22a1 1 0 0 1-1-1V3a1 1 0 0 1 2 0v18a1 1 0 0 1-1 1zM15.5 2.134A1 1 0 0 0 14 3v18a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V6.464a1 1 0 0 0-.5-.866l-6-3.464zM9 2a1 1 0 0 0-1 1v18a1 1 0 1 0 2 0V3a1 1 0 0 0-1-1z"></path>
              </svg>
              Your Library
            </span>
            <span class="lib-actions" style="position: relative;">
              <button class="lib-action-btn" title="Create playlist or folder" onclick="toggleLibraryAddDropdown(event)">
                <i class="fa-solid fa-plus"></i>
              </button>
              <button class="lib-action-btn" title="Show more">
                <i class="fa-solid fa-arrow-right"></i>
              </button>
              
              <!-- Floating Context Dropdown Menu -->
              <div class="library-add-dropdown" id="libraryAddDropdown" style="display: none;">
                <div class="library-dropdown-item" onclick="openPlaylistCreatePrompt()">
                  <div class="item-icon"><i class="fa-solid fa-music"></i></div>
                  <div class="item-text">
                    <span class="item-title">Playlist</span>
                    <span class="item-desc">Create a playlist with songs or episodes</span>
                  </div>
                </div>
                <div class="library-dropdown-item" onclick="handleDropdownCreateBlend(event)">
                  <div class="item-icon"><i class="fa-solid fa-arrows-rotate"></i></div>
                  <div class="item-text">
                    <span class="item-title">Blend</span>
                    <span class="item-desc">Combine your tastes with friends</span>
                  </div>
                </div>
                <div class="library-dropdown-item" onclick="handleDropdownCreateFolder(event)">
                  <div class="item-icon"><i class="fa-solid fa-folder"></i></div>
                  <div class="item-text">
                    <span class="item-title">Folder</span>
                    <span class="item-desc">Organize your playlists</span>
                  </div>
                </div>
              </div>
            </span>
          </div>
        </div>

        <div class="sidebar-section sidebar-library-body">
          <% if (!locals.user) { %>
            <div class="sidebar-cta-card">
              <h4>Create your first playlist</h4>
              <p>It's easy, we'll help you</p>
              <button class="cta-btn" onclick="openPlaylistCreatePrompt()">Create playlist</button>
            </div>
            <div class="sidebar-cta-card">
              <h4>Let's find some podcasts to follow</h4>
              <p>We'll keep you updated on new episodes</p>
              <button class="cta-btn" onclick="navigateTo('/spotify/podcasts')">Browse podcasts</button>
            </div>
          <% } %>

          <!-- Saved songs / playlists in sidebar -->
          <div class="sidebar-playlist" id="sidebarPlaylist">
            <% if (locals.user) { %>
              <!-- Special Liked Songs Item -->
              <div class="sidebar-playlist-item liked-songs-item" onclick="navigateTo('/spotify')">
                <div class="liked-badge-icon">
                  <i class="fa-solid fa-heart"></i>
                </div>
                <div class="sidebar-item-info">
                  <div class="sidebar-item-title">Liked Songs</div>
                  <div class="sidebar-item-subtitle">Playlist • <%= locals.savedSongs.length %> songs</div>
                </div>
              </div>

              <!-- Custom Playlists -->
              <% if (locals.playlists && locals.playlists.length > 0) { %>
                <% locals.playlists.forEach(p => { %>
                  <div class="sidebar-playlist-item playlist-item" data-playlist-id="<%= p.id %>" onclick="navigateTo('/spotify/playlist/<%= p.id %>')">
                    <div class="playlist-badge-icon">
                      <i class="fa-solid fa-music"></i>
                    </div>
                    <div class="sidebar-item-info">
                      <div class="sidebar-item-title"><%= p.name %></div>
                      <div class="sidebar-item-subtitle">Playlist • <%= p.songs ? p.songs.length : 0 %> songs</div>
                    </div>
                  </div>
                <% }) %>
              <% } %>

              <!-- Followed Artists -->
              <% if (locals.followedArtists && locals.followedArtists.length > 0) { %>
                <% locals.followedArtists.forEach(a => { %>
                  <div class="sidebar-playlist-item artist-item" data-browse-id="<%= a.browseId %>" onclick="navigateTo('/spotify/artist/<%= a.browseId %>')">
                    <img src="<%= a.thumbnail %>" alt="<%= a.name %>" style="border-radius: 50%;">
                    <div class="sidebar-item-info">
                      <div class="sidebar-item-title"><%= a.name %></div>
                      <div class="sidebar-item-subtitle">Artist</div>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            <% } else { %>
              <!-- Guest fallback -->
              <% const displayList = (locals.allListings) ? allListings : []; %>
              <% for(let listing of displayList) { %>
                <% const artwork = listing.videoId ? `https://i.ytimg.com/vi/${listing.videoId}/hqdefault.jpg` : (listing.image || ''); %>
                <div class="sidebar-playlist-item" <% if (listing.videoId) { %>data-video-id="<%= listing.videoId %>"<% } %> data-title="<%= listing.title %>" data-artist="<%= listing.artist %>" data-image="<%= artwork %>">
                  <img src="<%= artwork %>" data-video-id="<%= listing.videoId || '' %>" alt="" onerror="recoverThumbnail(this)">
                  <div class="sidebar-item-info">
                    <div class="sidebar-item-title"><%= listing.title %></div>
                    <div class="sidebar-item-subtitle">Song • <%= listing.artist %></div>
                  </div>
                </div>
              <% } %>
            <% } %>
          </div>
        </div>
      </aside>

      <main class="main-content" id="mainContent">
        <%- include('podcast_detail_content.ejs', { podcastData, browseId }) %>
      </main>
    </div>

    <!-- ===== PLAYER BAR ===== -->
    <div class="player-bar">
      <div class="player-left">
        <img src="" id="currentSongImg" alt="current song" class="player-album-art" title="Open full screen" onerror="recoverThumbnail(this)">
        <div class="track-info">
          <span class="track-name" id="currentSongTitle">No song selected</span>
          <span class="track-artist" id="currentSongArtist"></span>
        </div>
        <div class="track-actions">
          <button class="action-btn" id="btnLike" title="Save to Your Library"><i class="fa-solid fa-plus"></i></button>
        </div>
      </div>

      <div class="player-center">
        <div class="player-controls">
          <button class="control-btn" id="btnShuffle" title="Shuffle"><i class="fa-solid fa-shuffle"></i></button>
          <button class="control-btn" id="btnPrev" title="Previous"><i class="fa-solid fa-backward-step"></i></button>
          <button class="play-btn" id="ctrlIcn" onclick="playpause()" title="Play/Pause"><i class="fa-solid fa-play"></i></button>
          <button class="control-btn" id="btnNext" title="Next"><i class="fa-solid fa-forward-step"></i></button>
          <button class="control-btn" id="btnRepeat" title="Repeat"><i class="fa-solid fa-repeat"></i></button>
        </div>
        <div class="progress-bar-container">
          <span class="time-label" id="currentTime">0:00</span>
          <div class="progress-slider-wrap">
            <input type="range" min="0" value="0" id="progress" step="0.1">
            <div class="slider-progress" id="sliderProgress"></div>
          </div>
          <span class="time-label" id="totalTime">0:00</span>
        </div>
      </div>

      <div class="player-right">
        <button class="control-btn" id="btnNowPlaying" title="Now Playing View"><i class="fa-solid fa-circle-play"></i></button>
        <button class="control-btn" id="btnQueue" title="Queue"><i class="fa-solid fa-list-ul"></i></button>
        <div class="volume-control">
          <button class="control-btn" id="btnMute" title="Mute"><i class="fa-solid fa-volume-high"></i></button>
          <div class="volume-slider-wrap">
            <input type="range" min="0" max="1" step="0.05" value="1" id="volumeRange">
            <div class="slider-volume-progress" id="sliderVolumeProgress"></div>
          </div>
        </div>
        <button class="control-btn" id="btnFullscreen" title="Fullscreen"><i class="fa-solid fa-expand"></i></button>
      </div>
    </div>
  </div>

  <div id="ytPlayer" style="position: absolute; top: -9999px; left: -9999px; width: 1px; height: 1px; opacity: 0.001; pointer-events: none;"></div>
  <audio id="song"></audio>
  <script src="https://www.youtube.com/iframe_api"></script>
  <script src="/js/event.js?v=4.6"></script>
</body>
</html>
<% } %>
