<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= artistData.name %> | Spotify - Web Player</title>
  <meta name="description" content="Listen to <%= artistData.name %> on Spotify. <%= artistData.monthlyListeners || '' %>">
  <link rel="icon" type="image/png" href="/assets/main-logo.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/style.css?v=3.2">
</head>
<body>
  <div class="app-container">
    <!-- ===== TOP BAR ===== -->
    <header class="top-bar">
      <div class="top-bar-left">
        <a href="/spotify" class="spotify-logo-link" title="Spotify">
          <svg viewBox="0 0 24 24" height="32" width="32" fill="#fff" class="spotify-logo">
            <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424c-.18.295-.565.387-.86.207-2.377-1.454-5.37-1.783-8.892-.982-.336.076-.67-.135-.746-.47-.077-.337.135-.67.472-.747 3.854-.88 7.15-.508 9.818 1.127.294.18.387.563.208.865zm1.224-2.723c-.226.367-.707.487-1.074.26-2.72-1.672-6.87-2.157-10.078-1.182-.413.125-.85-.107-.978-.52-.128-.414.107-.85.52-.978 3.66-1.11 8.225-.565 11.35 1.354.366.226.486.707.26 1.066zm.105-2.81c-3.263-1.937-8.643-2.12-11.758-1.173-.5.152-1.025-.13-1.177-.63-.153-.5.13-1.026.63-1.178 3.614-1.098 9.544-.886 13.3 1.344.45.267.6.845.333 1.295-.266.45-.845.6-1.295.333z"/>
          </svg>
        </a>
      </div>

      <div class="top-bar-center">
        <a href="/spotify" class="home-btn" title="Home" id="homeBtn">
          <i class="fa-solid fa-house"></i>
        </a>
        <div class="search-wrap">
          <form class="search-box" onsubmit="return handleSearch(event)">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
            <input type="text" id="searchInput" placeholder="What do you want to play?" autocomplete="off">
            <span class="search-divider"></span>
            <button type="button" class="browse-btn" title="Browse">
              <svg viewBox="0 0 24 24" height="24" width="24" fill="currentColor">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-1 12H6v-2h12v2zm0-4H6V7h12v4z"/>
              </svg>
            </button>
          </form>
          <div class="search-results-dropdown" id="searchResults"></div>
        </div>
      </div>

      <div class="top-bar-right">
        <% if (user) { %>
          <button class="explore-btn" onclick="window.location.href='#'">Explore Premium</button>
          <button class="install-btn"><i class="fa-regular fa-circle-down"></i> Install App</button>
          <button class="icon-btn" title="Notifications"><i class="fa-regular fa-bell"></i></button>
          <button class="icon-btn" title="Social Feed"><i class="fa-solid fa-user-group"></i></button>
          <a href="/spotify/logout" class="profile-avatar" title="<%= user.username %> (Click to Log Out)">
            <%= user.username.charAt(0).toUpperCase() %>
          </a>
        <% } else { %>
          <a href="/spotify/signup" class="signup-link">Sign up</a>
          <a href="/spotify/login" class="login-btn">Log in</a>
        <% } %>
      </div>
    </header>

    <!-- ===== MAIN AREA (sidebar + content) ===== -->
    <div class="main-area">
      <!-- ===== SIDEBAR ===== -->
      <aside class="sidebar">
        <div class="sidebar-section sidebar-library-section">
          <div class="sidebar-library-header">
            <span class="lib-left">
              <svg class="lib-icon" role="img" height="24" width="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 22a1 1 0 0 1-1-1V3a1 1 0 0 1 2 0v18a1 1 0 0 1-1 1zM15.5 2.134A1 1 0 0 0 14 3v18a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V6.464a1 1 0 0 0-.5-.866l-6-3.464zM9 2a1 1 0 0 0-1 1v18a1 1 0 1 0 2 0V3a1 1 0 0 0-1-1z"></path>
              </svg>
              Your Library
            </span>
            <span class="lib-actions">
              <button class="lib-action-btn" title="Create playlist or folder">
                <i class="fa-solid fa-plus"></i>
              </button>
              <button class="lib-action-btn" title="Show more">
                <i class="fa-solid fa-arrow-right"></i>
              </button>
            </span>
          </div>
        </div>

        <div class="sidebar-section sidebar-library-body">
          <div class="sidebar-cta-card">
            <h4>Create your first playlist</h4>
            <p>It's easy, we'll help you</p>
            <button class="cta-btn" onclick="window.location.href='/spotify/add'">Create playlist</button>
          </div>
          <div class="sidebar-cta-card">
            <h4>Let's find some podcasts to follow</h4>
            <p>We'll keep you updated on new episodes</p>
            <button class="cta-btn">Browse podcasts</button>
          </div>

          <!-- Saved songs in sidebar -->
          <div class="sidebar-playlist" id="sidebarPlaylist">
            <% const displayList = savedSongs || []; %>
            <% for(let listing of displayList) { %>
              <div class="sidebar-playlist-item" <% if (listing.videoId) { %>data-video-id="<%= listing.videoId %>"<% } %> data-title="<%= listing.title %>" data-artist="<%= listing.artist %>" data-image="<%= listing.image ? listing.image : '/assets/card3img.jpeg' %>">
                <img src="<%= listing.image ? listing.image : '/assets/card3img.jpeg' %>" alt="" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
                <div class="sidebar-item-info">
                  <div class="sidebar-item-title"><%= listing.title %></div>
                  <div class="sidebar-item-subtitle"><%= listing.artist %></div>
                </div>
              </div>
            <% } %>
          </div>
        </div>

        <div class="sidebar-footer">
          <div class="footer-links">
            <a href="#">Legal</a>
            <a href="#">Safety &amp; Privacy Center</a>
            <a href="#">Privacy Policy</a>
            <a href="#">Cookies</a>
          </div>
          <div class="footer-links">
            <a href="#">About Ads</a>
            <a href="#">Accessibility</a>
          </div>
          <a href="#" class="footer-cookies-link">Cookies</a>
          <button class="language-btn">
            <i class="fa-solid fa-globe"></i> English
          </button>
        </div>
      </aside>

      <!-- ===== MAIN CONTENT - ARTIST PAGE ===== -->
      <main class="main-content" id="mainContent">
        <!-- Artist Hero Section -->
        <div class="artist-hero">
          <div class="artist-hero-bg" style="background-image: url('<%= artistData.banner || artistData.thumbnail || '' %>');"></div>
          <div class="artist-hero-gradient"></div>
          <div class="artist-hero-content">
            <% if (artistData.verified) { %>
              <div class="artist-verified">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="#3d91f4">
                  <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                <span>Verified Artist</span>
              </div>
            <% } %>
            <h1 class="artist-name"><%= artistData.name %></h1>
            <% if (artistData.monthlyListeners) { %>
              <p class="artist-listeners"><%= artistData.monthlyListeners %></p>
            <% } %>
          </div>
        </div>

        <!-- Artist Actions -->
        <div class="artist-actions">
          <button class="artist-play-btn" title="Play">
            <i class="fa-solid fa-play"></i>
          </button>
          <button class="artist-follow-btn">Follow</button>
          <button class="action-btn" title="More options">
            <i class="fa-solid fa-ellipsis"></i>
          </button>
        </div>

        <!-- Top Layout Grid: Popular tracks + Artist pick -->
        <div class="artist-top-layout">
          <!-- Popular Songs -->
          <% if (artistData.popularSongs && artistData.popularSongs.length > 0) { %>
            <div class="popular-tracks" style="padding: 0;">
              <h2>Popular</h2>
              <div class="tracks-table">
                <% artistData.popularSongs.forEach(function(song, index) { %>
                  <div class="track-row" data-video-id="<%= song.videoId %>" data-title="<%= song.title %>" data-artist="<%= song.artists %>" data-thumbnail="<%= song.thumbnail %>">
                    <div class="track-number">
                      <span class="track-num-text"><%= index + 1 %></span>
                      <button class="track-play-icon"><i class="fa-solid fa-play"></i></button>
                    </div>
                    <div class="track-title-col">
                      <img class="track-img" src="<%= song.thumbnail %>" alt="<%= song.title %>" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
                      <div class="track-title-info">
                        <span class="track-title-text"><%= song.title %></span>
                        <span class="track-artists-text"><%= song.artists %></span>
                      </div>
                    </div>
                    <div class="track-plays"><%= song.plays ? song.plays.replace(/\B(?=(\d{3})+(?!\d))/g, ',') : '' %></div>
                    <div class="track-duration"><%= song.duration %></div>
                  </div>
                <% }); %>
              </div>
            </div>
          <% } %>

          <!-- Artist Pick Column -->
          <% if (artistData.artistPick) { %>
            <div class="artist-pick-container">
              <h2>Artist pick</h2>
              <div class="artist-pick-card" <% if (artistData.artistPick.videoId) { %>data-video-id="<%= artistData.artistPick.videoId %>"<% } %> <% if (artistData.artistPick.browseId) { %>data-browse-id="<%= artistData.artistPick.browseId %>"<% } %> data-title="<%= artistData.artistPick.title %>" data-artist="<%= artistData.artistPick.subtitle %>">
                <img class="artist-pick-img" src="<%= artistData.artistPick.thumbnail %>" alt="" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
                <div class="artist-pick-info">
                  <div class="artist-pick-badge">
                    <i class="fa-solid fa-compact-disc"></i>
                    <span><%= artistData.artistPick.label %></span>
                  </div>
                  <div class="artist-pick-title"><%= artistData.artistPick.title %></div>
                  <div class="artist-pick-type"><%= artistData.artistPick.subtitle %></div>
                </div>
              </div>
            </div>
          <% } %>
        </div>

        <!-- Discography Section -->
        <% const allReleases = (artistData.albums || []).concat(artistData.singles || []); %>
        <% if (allReleases.length > 0) { %>
          <div class="discography-section">
            <div class="discography-header">
              <h2>Discography</h2>
              <a href="#" class="show-all">Show all</a>
            </div>
            <div class="discography-tabs">
              <button class="disco-tab active" data-filter="all">Popular releases</button>
              <button class="disco-tab" data-filter="albums">Albums</button>
              <button class="disco-tab" data-filter="singles">Singles and EPs</button>
              <button class="disco-tab" data-filter="compilations">Compilations</button>
            </div>
            <div class="card-row">
              <% allReleases.forEach(function(item) { %>
                <div class="song-card disco-card" <% if (item.videoId) { %>data-video-id="<%= item.videoId %>"<% } %> <% if (item.browseId) { %>data-browse-id="<%= item.browseId %>"<% } %> data-title="<%= item.title %>" data-artist="<%= item.subtitle %>" data-type="<%= item.type %>" data-subtitle="<%= item.subtitle %>">
                  <div class="card-img-wrap">
                    <img src="<%= item.thumbnail %>" alt="<%= item.title %>" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
                    <button class="play-btn-overlay"><i class="fa-solid fa-play"></i></button>
                  </div>
                  <div class="card-title"><%= item.title %></div>
                  <div class="card-subtitle-multi"><%= item.subtitle %></div>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>

        <!-- Featuring Section -->
        <% if (artistData.featuredOn && artistData.featuredOn.length > 0) { %>
          <div class="artist-carousel-section">
            <div class="artist-carousel-section-header">
              <h2>Featuring <%= artistData.name %></h2>
              <a href="#" class="show-all">Show all</a>
            </div>
            <div class="card-row">
              <% artistData.featuredOn.forEach(function(item) { %>
                <div class="song-card" <% if (item.videoId) { %>data-video-id="<%= item.videoId %>"<% } %> <% if (item.browseId) { %>data-browse-id="<%= item.browseId %>"<% } %> data-title="<%= item.title %>" data-artist="<%= item.subtitle %>">
                  <div class="card-img-wrap">
                    <img src="<%= item.thumbnail %>" alt="<%= item.title %>" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
                    <button class="play-btn-overlay"><i class="fa-solid fa-play"></i></button>
                  </div>
                  <div class="card-title"><%= item.title %></div>
                  <div class="card-subtitle-multi"><%= item.subtitle %></div>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>

        <!-- About Section -->
        <% if (artistData.aboutDescription) { %>
          <div class="about-section">
            <h2>About</h2>
            <div class="about-card" style="background-image: url('<%= artistData.banner || artistData.thumbnail || '' %>');">
              <div class="about-overlay">
                <div class="about-listeners">
                  <%= artistData.aboutMonthlyListeners || artistData.monthlyListeners || '' %>
                </div>
                <div class="about-description">
                  <%= artistData.aboutDescription %>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <!-- Discovered On Section -->
        <% if (artistData.playlists && artistData.playlists.length > 0) { %>
          <div class="artist-carousel-section">
            <div class="artist-carousel-section-header">
              <h2>Discovered on</h2>
              <a href="#" class="show-all">Show all</a>
            </div>
            <div class="card-row">
              <% artistData.playlists.forEach(function(item) { %>
                <div class="song-card" <% if (item.videoId) { %>data-video-id="<%= item.videoId %>"<% } %> <% if (item.browseId) { %>data-browse-id="<%= item.browseId %>"<% } %> data-title="<%= item.title %>" data-artist="<%= item.subtitle %>">
                  <div class="card-img-wrap">
                    <img src="<%= item.thumbnail %>" alt="<%= item.title %>" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
                    <button class="play-btn-overlay"><i class="fa-solid fa-play"></i></button>
                  </div>
                  <div class="card-title"><%= item.title %></div>
                  <div class="card-subtitle-multi"><%= item.subtitle %></div>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>

        <!-- Fans Also Like Section -->
        <% if (artistData.fansAlsoLike && artistData.fansAlsoLike.length > 0) { %>
          <div class="artist-carousel-section">
            <div class="artist-carousel-section-header">
              <h2>Fans also like</h2>
              <a href="#" class="show-all">Show all</a>
            </div>
            <div class="card-row">
              <% artistData.fansAlsoLike.forEach(function(item) { %>
                <div class="artist-card" data-browse-id="<%= item.browseId %>" data-title="<%= item.title %>" data-subtitle="<%= item.subtitle %>">
                  <div class="card-img-wrap">
                    <img src="<%= item.thumbnail %>" alt="<%= item.title %>" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
                    <button class="play-btn-overlay"><i class="fa-solid fa-play"></i></button>
                  </div>
                  <div class="card-title"><%= item.title %></div>
                  <div class="card-subtitle"><%= item.subtitle %></div>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>

        <!-- Discography filter tabs client-side logic -->
        <script>
          document.addEventListener("DOMContentLoaded", function() {
            const tabs = document.querySelectorAll(".disco-tab");
            const cards = document.querySelectorAll(".disco-card");

            tabs.forEach(tab => {
              tab.addEventListener("click", function() {
                tabs.forEach(t => t.classList.remove("active"));
                tab.classList.add("active");

                const filter = tab.dataset.filter;
                cards.forEach(card => {
                  const type = card.dataset.type;
                  const subtitle = (card.dataset.subtitle || '').toLowerCase();
                  
                  if (filter === "all") {
                    card.style.display = "block";
                  } else if (filter === "albums") {
                    if (type === "album" || (subtitle.includes("album") && !subtitle.includes("single") && !subtitle.includes("ep"))) {
                      card.style.display = "block";
                    } else {
                      card.style.display = "none";
                    }
                  } else if (filter === "singles") {
                    if (type === "single" || subtitle.includes("single") || subtitle.includes("ep")) {
                      card.style.display = "block";
                    } else {
                      card.style.display = "none";
                    }
                  } else if (filter === "compilations") {
                    if (subtitle.includes("compilation")) {
                      card.style.display = "block";
                    } else {
                      card.style.display = "none";
                    }
                  }
                });
              });
            });
          });
        </script>
      </main>

      <!-- ===== NOW PLAYING PANEL (right sidebar, hidden by default) ===== -->
      <aside class="now-playing-panel" id="nowPlayingPanel">
        <div class="np-header">
          <span class="np-header-title" id="npArtistName"></span>
          <button class="np-close-btn" id="npCloseBtn" title="Close">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
        <div class="np-artist-image-wrap">
          <img src="/assets/card3img.jpeg" alt="" id="npArtistImg" class="np-artist-img" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
          <button class="np-follow-btn">Follow</button>
        </div>
        <div class="np-song-info">
          <div class="np-song-title" id="npSongTitle"></div>
          <div class="np-song-artists" id="npSongArtists"></div>
          <button class="np-add-btn" title="Add to library"><i class="fa-solid fa-circle-plus"></i></button>
        </div>
        <div class="np-credits-section">
          <div class="np-credits-header">
            <span>Credits</span>
            <a href="#" class="show-all">Show all</a>
          </div>
          <div class="np-credits-list" id="npCreditsList">
            <!-- Credits populated by JS -->
          </div>
        </div>
        <div class="np-queue-section">
          <div class="np-queue-header">
            <span>Next in queue</span>
            <a href="#" class="show-all">Open queue</a>
          </div>
          <div class="np-queue-list" id="npQueueList">
            <!-- Queue populated by JS -->
          </div>
        </div>
      </aside>

      <!-- ===== QUEUE PANEL (right sidebar, hidden by default) ===== -->
      <aside class="queue-panel" id="queuePanel">
        <div class="q-header">
          <span class="q-header-title">Queue</span>
          <button class="q-close-btn" id="qCloseBtn" title="Close">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
        <div class="q-content">
          <div class="q-section">
            <h3 class="q-section-title">Now playing</h3>
            <div class="q-now-playing-item" id="qNowPlayingItem">
              <!-- Current song populated by JS -->
            </div>
          </div>
          <div class="q-section">
            <h3 class="q-section-title" id="qNextFromHeader">Next from:</h3>
            <div class="q-list" id="qList">
              <!-- Upcoming queue list populated by JS -->
            </div>
          </div>
        </div>
      </aside>
    </div>

    <!-- ===== PREVIEW BANNER ===== -->
    <div class="preview-banner">
      <div class="banner-content">
        <p class="banner-title">Preview of Spotify</p>
        <p class="banner-subtitle">Sign up to get unlimited songs and podcasts with occasional ads. No credit card needed.</p>
      </div>
      <button class="btn-signup-free">Sign up free</button>
    </div>

    <!-- ===== PLAYER BAR ===== -->
    <div class="player-bar">
      <div class="player-left">
        <img src="/assets/card3img.jpeg" id="currentSongImg" alt="current song" class="player-album-art" title="Open full screen" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
        <div class="track-info">
          <span class="track-name" id="currentSongTitle">No song selected</span>
          <span class="track-artist" id="currentSongArtist"></span>
        </div>
        <div class="track-actions">
          <button class="action-btn" id="btnLike" title="Save to Your Library"><i class="fa-regular fa-circle-plus"></i></button>
        </div>
      </div>

      <div class="player-center">
        <div class="player-controls">
          <button id="btnShuffle" title="Enable shuffle"><i class="fa-solid fa-shuffle"></i></button>
          <button id="btnPrev" title="Previous"><i class="fa-solid fa-backward-step"></i></button>
          <button class="btn-play" id="ctrlIcn" onclick="playpause()">
            <i class="fa-solid fa-play"></i>
          </button>
          <button id="btnNext" title="Next"><i class="fa-solid fa-forward-step"></i></button>
          <button id="btnRepeat" title="Enable repeat"><i class="fa-solid fa-repeat"></i></button>
        </div>
        <div class="progress-row">
          <span id="currentTime">1:03</span>
          <div class="progress-bar-wrap">
            <input type="range" id="progress" min="0" max="100" value="28">
          </div>
          <span id="totalTime">3:46</span>
        </div>
      </div>

      <div class="player-right">
        <button class="action-btn" id="btnNowPlaying" title="Lyrics"><i class="fa-solid fa-microphone"></i></button>
        <button class="action-btn" id="btnQueueToggle" title="Queue"><i class="fa-solid fa-bars"></i></button>
        <button class="action-btn" title="Connect to a device"><i class="fa-solid fa-laptop"></i></button>
        <button class="action-btn volume-btn" id="btnVolume" title="Mute"><i class="fa-solid fa-volume-high" id="volumeIcon"></i></button>
        <div class="volume-bar-wrap">
          <input type="range" id="volumeSlider" min="0" max="1" step="0.01" value="0.5">
        </div>
        <button class="action-btn" id="btnFullscreen" title="Full screen"><i class="fa-solid fa-expand"></i></button>
      </div>
    </div>
  </div>

  <!-- ===== FULLSCREEN OVERLAY ===== -->
  <div class="fullscreen-overlay" id="fullscreenOverlay">
    <div class="fs-top-bar">
      <span class="fs-artist-name" id="fsArtistName"></span>
      <div class="fs-actions">
        <button class="fs-action-btn" title="Settings"><i class="fa-solid fa-gear"></i></button>
        <button class="fs-action-btn" title="Miniplayer"><i class="fa-solid fa-window-restore"></i></button>
        <button class="fs-action-btn" title="View Artist"><i class="fa-solid fa-user"></i></button>
        <button class="fs-action-btn" title="More"><i class="fa-solid fa-ellipsis"></i></button>
        <button class="fs-action-btn" id="fsExitBtn" title="Exit full screen"><i class="fa-solid fa-down-left-and-up-right-to-center"></i></button>
        <button class="fs-action-btn" id="fsCloseBtn" title="Close"><i class="fa-solid fa-xmark"></i></button>
      </div>
    </div>
    <div class="fs-content">
      <img src="/assets/card3img.jpeg" alt="" id="fsAlbumArt" class="fs-album-art" onerror="if(this.src.includes('maxresdefault.jpg')){this.src=this.src.replace('maxresdefault.jpg','hqdefault.jpg');}else{this.src='/assets/card3img.jpeg';}">
    </div>
    <div class="fs-bottom">
      <div class="fs-bottom-sections">
        <div class="fs-credits-section">
          <div class="fs-section-header">
            <span>Credits</span>
            <a href="#" class="show-all">Show all</a>
          </div>
          <div class="fs-credits-list" id="fsCreditsList"></div>
        </div>
        <div class="fs-queue-section">
          <div class="fs-section-header">
            <span>Next in queue</span>
            <a href="#" class="show-all">Open queue</a>
          </div>
          <div class="fs-queue-list" id="fsQueueList"></div>
        </div>
      </div>
    </div>
  </div>

  <audio id="song"></audio>
  <script src="/js/event.js?v=3.2"></script>
</body>
</html>
