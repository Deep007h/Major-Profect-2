<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Spotify Clone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #121212; color: #fff; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .error-container { text-align: center; }
        .error-container h1 { font-size: 6rem; color: #1ed760; margin-bottom: 0; }
        .error-container h2 { margin-bottom: 20px; }
        .error-container p { color: #b3b3b3; margin-bottom: 30px; }
        .error-container .btn-success { background-color: #1ed760; border: none; color: #000; font-weight: bold; }
    </style>
</head>
<body>
    <div class="error-container">
        <h1><%= typeof statusCode !== 'undefined' ? statusCode : '500' %></h1>
        <h2>Oops! Something went wrong.</h2>
        <p><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>
        <a href="/spotify" class="btn btn-success btn-lg">Back to Home</a>
    </div>
</body>
</html>
