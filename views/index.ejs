<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Spotify - Web Player: Music for every Moment</title>
  <link rel="icon" type="image/png" href="/assets/main-logo.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <% if (success && success.length > 0) { %>
    <div class="flash-container">
      <% success.forEach(msg => { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% }); %>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="flash-container">
      <% error.forEach(msg => { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% }); %>
    </div>
  <% } %>

  <div class="app-container">
    <div class="main-area">
      <!-- ===== SIDEBAR ===== -->
      <aside class="sidebar">
        <div class="sidebar-logo">
          <img src="/assets/logo.png" alt="Spotify">
        </div>
        <ul class="sidebar-nav">
          <li class="active"><i class="fa-solid fa-house"></i> Home</li>
          <li><i class="fa-solid fa-magnifying-glass"></i> Search</li>
        </ul>
        <div class="sidebar-divider"></div>
        <div class="sidebar-library-header">
          <span class="lib-left"><i class="fa-solid fa-book"></i> Your Library</span>
          <i class="fa-solid fa-plus"></i>
        </div>
        <div class="sidebar-playlist" id="sidebarPlaylist">
          <% for(let listing of allListings) { %>
            <div class="search-result-item" style="border-radius:4px;" <% if (listing.videoId) { %>data-video-id="<%= listing.videoId %>"<% } %> data-title="<%= listing.title %>" data-artist="<%= listing.artist %>" data-image="<%= listing.image ? listing.image : '/assets/card3img.jpeg' %>">
              <img src="<%= listing.image ? listing.image : '/assets/card3img.jpeg' %>" alt="" onerror="this.src='/assets/card3img.jpeg'">
              <div class="search-result-info">
                <div class="search-result-title"><%= listing.title %></div>
                <div class="search-result-artist"><%= listing.artist %></div>
              </div>
            </div>
          <% } %>
          <% if (allListings.length === 0) { %>
            <div style="padding:8px 12px;color:#b3b3b3;font-size:13px;">
              No songs yet. Search above to add.
            </div>
          <% } %>
        </div>
      </aside>

      <!-- ===== MAIN CONTENT ===== -->
      <main class="main-content">
        <div class="top-bar">
          <div class="top-bar-left">
            <div class="nav-buttons">
              <button><i class="fa-solid fa-chevron-left"></i></button>
              <button><i class="fa-solid fa-chevron-right"></i></button>
            </div>
            <div class="search-wrap">
              <form class="search-box" onsubmit="return handleSearch(event)">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="searchInput" placeholder="What do you want to listen to?" />
              </form>
              <div class="search-results-dropdown" id="searchResults"></div>
            </div>
          </div>
          <div class="top-bar-right">
            <button class="btn-upgrade">Explore Premium</button>
            <button class="btn-login">Log in</button>
          </div>
        </div>

        <div class="greeting">Trending</div>

        <div class="content-section">
          <div class="content-section-header">
            <h2>Songs</h2>
            <a href="/spotify/add">Add song</a>
          </div>
          <div class="song-grid" id="songPanel">
            <% for(let listing of allListings) { %>
              <div class="song-card" <% if (listing.videoId) { %>data-video-id="<%= listing.videoId %>"<% } %> data-title="<%= listing.title %>" data-artist="<%= listing.artist %>">
                <img src="<%= listing.image ? listing.image : '/assets/card3img.jpeg' %>" alt="<%= listing.title %>" onerror="this.src='/assets/card3img.jpeg'">
                <div class="card-title"><%= listing.title %></div>
                <div class="card-artist"><%= listing.artist %></div>
                <button class="play-btn-overlay"><i class="fa-solid fa-play"></i></button>
                <form action="/spotify/song/<%= listing._id %>?_method=DELETE" method="POST" style="display:none;">
                  <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
              </div>
            <% } %>
            <% if (allListings.length === 0) { %>
              <div class="no-songs-msg">No songs yet. Search above to find any song on YouTube Music!</div>
            <% } %>
          </div>
        </div>
      </main>
    </div>

    <!-- ===== PLAYER BAR ===== -->
    <div class="player-bar">
      <div class="player-left">
        <img src="/assets/card3img.jpeg" id="currentSongImg" alt="current song">
        <div class="track-info">
          <span class="track-name" id="currentSongTitle">No song selected</span>
          <span class="track-artist" id="currentSongArtist"></span>
        </div>
        <div class="track-actions">
          <i class="fa-regular fa-heart"></i>
          <i class="fa-regular fa-image"></i>
        </div>
      </div>

      <div class="player-center">
        <div class="player-controls">
          <button id="btnShuffle" title="Shuffle"><i class="fa-solid fa-shuffle"></i></button>
          <button id="btnPrev" title="Previous"><i class="fa-solid fa-backward-step"></i></button>
          <button class="btn-play" id="ctrlIcn" onclick="playpause()">
            <i class="fa-solid fa-play"></i>
          </button>
          <button id="btnNext" title="Next"><i class="fa-solid fa-forward-step"></i></button>
          <button id="btnRepeat" title="Repeat"><i class="fa-solid fa-repeat"></i></button>
        </div>
        <div class="progress-row">
          <span id="currentTime">0:00</span>
          <input type="range" id="progress" min="0" max="100" value="0">
          <span id="totalTime">0:00</span>
        </div>
      </div>

      <div class="player-right">
        <i class="fa-regular fa-copy"></i>
        <i class="fa-solid fa-microchip"></i>
        <i class="fa-solid fa-list"></i>
        <i class="fa-solid fa-display"></i>
        <i class="fa-solid fa-volume-high"></i>
        <input type="range" id="volumeSlider" min="0" max="1" step="0.01" value="0.5">
        <i class="fa-solid fa-expand"></i>
      </div>
    </div>
  </div>

  <audio id="song"></audio>

  <script src="/js/event.js"></script>
</body>
</html>
