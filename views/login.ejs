<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Spotify Clone</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/login-style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="main-body">
        <div class="upper-body-logo">
            <img src="/assets/logo.png" class="spotify-logo" alt="spotify-logo">
        </div>
        <div class="upper-body-heading">
            <p class="Heading">Log in to Spotify</p>
        </div>
        <div class="upper-body-btns">
            <form class="btn-form">
                <button type="submit" class="btn btn-dark"><img class="img-big" src="/assets/google_img.png" alt="google">Continue with Google</button>
            </form>
            <form>
                <button type="submit" class="btn btn-dark"><img class="img-big" src="/assets/facebook_logo.png" alt="facebook">Continue with Facebook</button>
            </form>
            <form>
                <button type="submit" class="btn btn-dark"><img class="img-small" src="/assets/apple_logo.png" alt="apple">Continue with Apple</button>
            </form>
            <form>
                <button type="submit" class="btn btn-dark">Continue with phone number</button>
            </form>
        </div>
        <div class="divider">
            <div class="divider-line"></div>
        </div>
        <div class="lower-body-inputs">
            <div class="input-box">
                <form method="POST" action="/spotify/login">
                    <p class="email">Email or username</p>
                    <input class="input-form" type="text" name="username" placeholder="Email or username" required />
                </form>
            </div>
            <div class="continue-btn">
                <form method="POST" action="/spotify/login">
                    <button type="submit" class="btn btn-success">Continue</button>
                </form>
            </div>
        </div>
        <div class="lower-body-signup-link">
            <p class="last-link">Don't have an account? </p>
            <a href="#/" name="signup-for-spotify"> Sign up for Spotify</a>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
