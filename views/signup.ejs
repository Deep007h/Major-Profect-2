<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign up - Spotify Clone</title>
  <link rel="icon" type="image/png" href="/assets/main-logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/login-style.css">
</head>
<body>
  <div class="main-body">
    <div class="upper-body-logo">
      <img src="/assets/main-logo.png" class="spotify-logo" alt="spotify-logo">
    </div>
    <div class="upper-body-heading">
      <h1 class="Heading">Sign up to Spotify</h1>
    </div>

    <!-- Flash Messages inside Signup Box -->
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error">
        <%= error %>
      </div>
    <% } %>
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">
        <%= success %>
      </div>
    <% } %>

    <div class="lower-body-inputs">
      <form method="POST" action="/spotify/signup" class="auth-form">
        <div class="form-group">
          <label for="username">Create username</label>
          <input class="input-form" type="text" id="username" name="username" placeholder="Choose a username" required minlength="3" maxlength="20" />
        </div>
        <div class="form-group">
          <label for="password">Create password</label>
          <input class="input-form" type="password" id="password" name="password" placeholder="Choose a password" required minlength="4" />
        </div>
        <button type="submit" class="btn btn-success">Sign Up</button>
      </form>
    </div>

    <div class="divider">
      <div class="divider-line"></div>
    </div>

    <div class="lower-body-signup-link">
      <p class="last-link">Already have an account?</p>
      <a href="/spotify/login">Log in here</a>
    </div>

    <div style="margin-top: 16px;">
      <a href="/spotify" style="color: #a7a7a7; font-size: 13px; font-weight: 500; text-decoration: underline;">Back to player</a>
    </div>
  </div>
</body>
</html>
