<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Song - Spotify Clone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #121212; color: #fff; }
        .add-container {
            max-width: 500px;
            margin: 50px auto;
            padding: 30px;
            background: #181818;
            border-radius: 12px;
        }
        .add-container h2 { margin-bottom: 20px; color: #1ed760; }
        .add-container .btn-success { background-color: #1ed760; border: none; color: #000 !important; font-weight: bold; }
        .add-container .btn-success:hover { background-color: #3be477; }
        .add-container .form-control { background-color: #2a2a2a; border: 1px solid #333; color: #fff; }
        .add-container .form-control:focus { background-color: #333; border-color: #1ed760; color: #fff; box-shadow: none; }
        .back-link { color: #b3b3b3; margin-top: 20px; display: inline-block; }
        .back-link:hover { color: #fff; }
    </style>
</head>
<body>
    <%- include('navbar.ejs') %>

    <div class="container">
        <% if (typeof success !== 'undefined' && success.length > 0) { %>
            <% success.forEach(msg => { %>
                <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                    <%= msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% }); %>
        <% } %>
        <% if (typeof error !== 'undefined' && error.length > 0) { %>
            <% error.forEach(msg => { %>
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    <%= msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% }); %>
        <% } %>

        <div class="add-container">
            <h2>Add Song Details</h2>
            <p class="text-muted">Enter the metadata for your uploaded audio.</p>
            <form method="POST" action="/add-user">
                <div class="mb-3">
                    <label for="title" class="form-label">Song Title *</label>
                    <input type="text" class="form-control" id="title" name="title" placeholder="Enter song title" required maxlength="200">
                </div>
                <div class="mb-3">
                    <label for="artist" class="form-label">Artist Name *</label>
                    <input type="text" class="form-control" id="artist" name="artist" placeholder="Enter artist name" required maxlength="200">
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Album Art Image URL</label>
                    <input type="url" class="form-control" id="image" name="image" placeholder="https://example.com/album-art.jpg (optional)">
                    <small class="text-muted">Optional. Leave empty to use default cover art.</small>
                </div>
                <button type="submit" class="btn btn-success w-100">Add Song</button>
            </form>
            <a href="/spotify" class="back-link">&larr; Back to Home</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
